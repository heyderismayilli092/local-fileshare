# GUI texts
msgid "Software for Linux operating systems that enables easy browser-based file sharing over a local network among other devices"
msgstr "Linux işletim sistemleri için, yerel ağ üzerinden diğer cihazlar arasında tarayıcı tabanlı kolay dosya paylaşımını sağlayan yazılım"

msgid "Local File Share"
msgstr "Yerel Dosya Paylaşımı"

msgid "Select the folder to share:"
msgstr "Paylaşılacak klasörü seçiniz:"

msgid "Connect to a network and try again !"
msgstr "Ağ bağlantısı kurup tekrar deneyin !"

msgid "Share"
msgstr "Paylaş"

msgid "🟢  Open your browser on your other device connected to the same network\n🌎  Enter the following address exactly as it is into the browser that opens:"
msgstr "🟢 Aynı ağa bağlı diğer cihazınızda tarayıcınızı açın\n🌎 Açılan tarayıcıya aşağıdaki adresi aynen olduğu gibi girin:"

msgid "You haven't selected any folder path!"
msgstr "Herhangi bir klasör yolu seçmediniz!"

msgid "Enter the password:"
msgstr "Şifre giriniz:"

msgid "For security purposes, you will first need to enter a password.\nYou will use this password to access the interface."
msgstr "Güvenlik amacıyla öncelikle bir parola girmeniz gerekecektir.\nBu parolayı arayüze erişmek için kullanacaksınız."

msgid "Shared folder:"
msgstr "Paylaşılan klasör:"

msgid "Stop File Sharing"
msgstr "Dosya Paylaşımını Durdur"

msgid "Scan the QR Code"
msgstr "QR Kodu tarayınız"

msgid "QR Code"
msgstr "QR Kod"

msgid "Scan the QR code below to access the link"
msgstr "Bağlantıya erişmek için aşağıdaki QR kodunu tarayın"

msgid "Scan the QR code below with your phone or tablet:"
msgstr "Aşağıdaki QR kodunu telefonunuz veya tabletinizle tarayınız:"

# Interface texts
msgid "Local FileShare"
msgstr "Yerel Dosya Paylaşımı"

msgid "Drag the files here"
msgstr "Dosyaları buraya sürükleyin"

msgid "or select from your device"
msgstr "veya cihazınızdan seçin"

msgid "Uploading..."
msgstr "Yükleniyor..."

msgid "Shared by User:"
msgstr "Paylaşan Kullanıcı:"

msgid "Shared Files"
msgstr "Paylaşılan Dosyalar"

msgid "No files yet"
msgstr "Henüz dosya yok"

# Login interface texts
msgid "Login Window"
msgstr "Giriş Ekranı"

msgid "Enter the password you set:"
msgstr "Belirlediğiniz şifreyi giriniz:"

msgid "Login"
msgstr "Giriş"
